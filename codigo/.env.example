# Configuración local de GRAIA (duplicar como .env y ajustar)

# Endpoint de Ollama (por defecto local)
OLLAMA_HOST=http://localhost:11434

# Modelo LLM y de embeddings
GRAIA_LLM_MODEL=llama3.1:8b-instruct-q4_K_M
GRAIA_EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Ruta al fichero de configuración por defecto
GRAIA_CONFIG=config/default.yaml

# Nivel de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
GRAIA_LOG_LEVEL=INFO
